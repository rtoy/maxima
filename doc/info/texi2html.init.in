texinfo_set_from_init_file("EXTRA_HEAD",  q{<link rel="icon" href="figures/favicon.ico">
<!-- Select the theme to use for highlighting.  github looks pretty good for the examples
     in the manual -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/styles/github.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/highlight.min.js"></script>
<!-- and it's easy to individually load additional languages -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/languages/maxima.min.js">
</script>

<script>
  hljs.configure({
      languages: ['Maxima'],
      cssSelector: '.example-preformatted'
  });
  hljs.highlightAll();
</script>
}
);
